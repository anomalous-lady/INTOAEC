# ─────────────────────────────────────────
#  AEC Backend — Environment Variables
#  Copy this to .env and fill in your values
#  NEVER commit .env to version control
# ─────────────────────────────────────────

# ── Server ──────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
# Set to 1 if running behind nginx / Cloudflare / any reverse proxy
# so req.ip reflects the real client IP for rate limiting (not the proxy IP)
TRUST_PROXY=0

# ── Redis (optional but strongly recommended in production) ───────────────────
# Used by rate limiters so limits survive restarts and work across instances.
# Without this, rate limits reset every time the server restarts.
# Install: npm install rate-limit-redis ioredis
# Format: redis://[:password@]host[:port][/db]
# REDIS_URL=redis://localhost:6379

# ── MongoDB ──────────────────────────────
# Local:  mongodb://localhost:27017/intoaec
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/intoaec
MONGO_URI=mongodb://localhost:27017/intoaec
# authSource: DB that holds your credentials (usually 'admin' for Atlas)
MONGO_AUTH_SOURCE=admin

# ── JWT ──────────────────────────────────
# Generate strong secrets: node -e "require('crypto').randomBytes(64).toString('hex')|head"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_REFRESH_EXPIRES_IN=7d

# ── Cookie ───────────────────────────────
COOKIE_SECRET=REPLACE_WITH_32_CHAR_RANDOM_HEX

# ── File Uploads ─────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_PATH=./uploads

# ── Email (for verify / reset flows) ─────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM="AEC Platform <noreply@intoaec.com>"

# ── Rate Limiting ─────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Logging ───────────────────────────────
LOG_LEVEL=debug

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
# On first run, seed an admin account using the seed script:
#   node src/scripts/seedAdmin.js
# Then use the admin account to create invitations for all other users.
# Self-registration without an invite token is blocked at the API level.
ADMIN_SEED_EMAIL=admin@yourdomain.com
ADMIN_SEED_PASSWORD=ChangeMe_Str0ng!
